#!/usr/bin/env python3
"""brightness-ctl — color temperature and brightness daemon/CLI."""

import asyncio
import os
import sys
from pathlib import Path

# Add src/ to path for imports
sys.path.insert(0, str(Path(__file__).parent))

from cli import main as cli_main
from daemon import Daemon
from hardware import SubprocessBackend


def get_paths() -> dict:
    """Get standard paths for config, state, and socket."""
    config_dir = Path.home() / ".config" / "brightness-ctl"
    runtime_dir = os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}")
    return {
        "config_file": config_dir / "config.toml",
        "state_file": config_dir / "state.json",
        "socket_path": Path(runtime_dir) / "brightness-ctl.sock",
    }


def run_daemon(paths: dict) -> int:
    """Start the daemon."""
    daemon = Daemon(
        config_path=paths["config_file"],
        state_path=paths["state_file"],
        socket_path=paths["socket_path"],
        backend=SubprocessBackend(),
    )
    try:
        asyncio.run(daemon.run())
    except KeyboardInterrupt:
        pass
    return 0


def main() -> int:
    paths = get_paths()
    args = sys.argv[1:]

    if not args or args[0] in ("help", "--help", "-h"):
        return cli_main(str(paths["socket_path"]), args)

    cmd = args[0]
    aliases = {"d": "daemon"}
    cmd = aliases.get(cmd, cmd)

    if cmd == "daemon":
        return run_daemon(paths)

    return cli_main(str(paths["socket_path"]), args)


if __name__ == "__main__":
    sys.exit(main() or 0)
